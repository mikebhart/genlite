<section class="website-header-mobile">

    <div class="website-header-mobile-wrapper">

        <div class="container">

            <div class="row">

                <div class="col-9 text-left my-auto">

                    {% if header.logo is not empty %}

                        <div class="logo-icon-section">
                            <a href="{{ home_url }}" aria-label="Go to the homepage">
                                <img src="{{ header.logo.url }}" alt="Logo">
                            </a>
                        </div>

                        {% else %}

                        <div class="website-header__desktop-logo-text-wrapper">
                            <a href="{{ home_url }}" aria-label="Go to the homepage">
                                <h3>{{ header.logo_text }}</h3>
                                <h6>{{ header.logo_sub_text }}</h6>
                            </a>                
                        </div>

                    {% endif %}

                </div>

                <div class="col-3 text-right my-auto">

                    <div id="website-mobile-menu" class="logo-icon-section text-right">

                        <button class="website-header-mobile__button-wrapper">
                            <img id="website-mobile-menu-show" class="icon-btn" src="{{ theme.link }}/dist/images/menu-hamberger.svg" alt="Mobile Menu Open">
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <nav id="website_mobile_page_links" class="page-links">

            <div class="container">

                <div class="row">

                    <div class="col-12 text-right">

                        <button class="website-header-mobile__button-wrapper">
                            <img id="website-mobile-menu-close" class="icon-btn {% if user %} website-header-mobile__button-wrapper--open-user {% else %} website-header-mobile__button-wrapper--open {% endif %}" src="{{ theme.link }}/dist/images/menu-window-close.svg" alt="Mobile Menu Close">
                        </button>

            
                        <div class="mobile-menu-wraapper">
            
                            {% for item in header_menu.items %}
                                
                                {% if loop.last %}

                                    <div class="wp-block-button">
                                        <a class="wp-block-button__link has-text-align-center wp-element-button {% if item.current %} wp-block-button__current {% endif %}" href="{{ item.link }}">{{ item.title }}</a>
                                    </div>

                                {% else %}


                                    {% if item.children %}

                                        {% set count_level = 0 %}

                                        {% for item_child in item.children %}

                                            {% if item_child.children %}

                                                {% for item_level2_child in item_child.children %}

                                                    {% set count_level = count_level + 1 %}

                                                {% endfor %}

                                            {% endif %}

                                        {% endfor %}

                                        {% set sub_menu_id = 'mobile-submenu-' ~  item.slug ~ '-' ~ loop.index %}
 
                                        <a id="{{ item.slug }}-{{ loop.index }}" class="mobile-parent-menu mobile-parent-submenu {% if item.current_item_parent or item.current or item.path in post.path %} active-mobile-submenu {% endif %}" aria-label="{{ item.title }}">{{ item.title }}</a>

                                        <div id="{{ sub_menu_id }}" class="level1-subnav-container">

                                            <a id="mobile-submenu-back-{{ item.slug }}-{{ loop.index }}" class="mobile-submenu-back {% if count_level > 0 %} level2 {% endif %}">
                                                <img src="{{ theme.link }}/dist/images/arrow-left-solid.svg" class="back-button-icon" alt="Sub Menu go back">
                                            </a>


                                            {% for child in item.children %}

                                                {% if count_level > 0 %} 

                                                    <a id="{{ child.slug }}-{{ loop.index }}" class="level2-mobile-parent-menu {% if child.current or child.current_item_parent %} active-mobile-submenu {% endif %}" aria-label="{{ child.title }}">{{ child.title }}</a>

                                                    <div id="level2-mobile-submenu-container-{{ child.slug }}-{{ loop.index }}" class="level2-subnav-container">

                                                        {# <a id="level2-back-button-{{ child.slug }}-{{ loop.index }}" class="mobile-submenu-back level2">
                                                            <img src="{{ theme.link }}/dist/images/arrow-left-solid.svg" class="back-button-icon" alt="Sub Menu go back">
                                                        <a> #}


                                                        {% for child_level2 in child.children %}

                                                            <a class="level2-mobile-parent-submenu-level3 {% if child_level2.current %} active-mobile-submenu {% endif %}" href="{{ child_level2.link }}">{{ child_level2.title }}</a>

                                                        {% endfor %}

                                                    </div>

                                                {% else %}

                                                      <a class="submenu {% if child.current %} active-mobile-submenu {% endif %}" href="{{ child.link }}" aria-label="{{ child.title }}">{{ child.title }}</a>

                                                {% endif %}

                                            {% endfor %}


                                        </div>

                                    {% else %}

                                        <a id="{{ item.slug }}" class="mobile-parent-menu {% if item.current %} active {% endif %}" href="{{ item.link }}" aria-label="{{ item.title }}">{{ item.title }}</a>

                                    {% endif %}

                                {% endif %}
                            
                            {% endfor %}

                        </div>

                    </div>

                </div>

            </div>

        </nav>
        
    </div>

</section>
